    "# N = int(input())\n",
    "N = 5\n",
    "arr = [0] * N\n",
    "arr = list(map(int, input().split()))\n",
    "\n",
    "arr.sort(reverse=False)\n",
    "\n",
    "for i in arr:\n",
    "    if i%2 == 0:\n",
    "        print(i, end=' ')"
